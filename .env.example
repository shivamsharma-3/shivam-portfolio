# Contact form — Resend delivers submissions to your inbox.
# 1. Create a free account at https://resend.com
# 2. Grab your API key from https://resend.com/api-keys
# 3. Paste it below (starts with "re_...")
# Until this is set, submissions are logged to the server but NOT emailed.
RESEND_API_KEY=YOUR_VALUE_HERE

# Where submissions are delivered (defaults to shivamsharma4c@gmail.com).
CONTACT_RECIPIENT_EMAIL=YOUR_VALUE_HERE

# The "from" address. Resend's free tier lets you send from
# onboarding@resend.dev to your account email with zero domain setup —
# perfect for a personal portfolio. Change this only if you verify a
# custom domain in Resend.
CONTACT_FROM_EMAIL=YOUR_VALUE_HERE
